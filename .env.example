# ─────────────────────────────────────────────────────────────────────────────
# Tesla Lyrics — environment variables
# Copy this file to `.env.local` and fill in the values. Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# Your Spotify app's Client ID (from https://developer.spotify.com/dashboard).
SPOTIFY_CLIENT_ID=

# Your Spotify app's Client Secret. SERVER-SIDE ONLY — never exposed to the browser.
SPOTIFY_CLIENT_SECRET=

# The exact redirect URI registered in the Spotify dashboard.
# Local dev (Spotify banned `localhost`, so use 127.0.0.1 over http for dev):
#   http://127.0.0.1:3000/api/auth/callback
# Production (must be HTTPS):
#   https://your-domain.com/api/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# 32+ char random secret used to encrypt the session cookie (AES-256-GCM via JWE).
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=

# Descriptive User-Agent sent to LRCLIB (they ask API users to identify themselves).
# Optional — a sensible default is used if unset.
LRCLIB_USER_AGENT=tesla-lyrics (https://github.com/your/repo)

# DeepSeek API key, used to generate on-demand lyric-line explanations.
# SERVER-SIDE ONLY — never exposed to the browser. Get one at https://platform.deepseek.com.
DEEPSEEK_API_KEY=
